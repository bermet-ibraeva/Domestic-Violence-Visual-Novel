  m_text: "\u041A\u043E\u0433\u0434\u0430 \u0433\u0430\u0441\u043D\u0435\u0442 \u0441\u0432\u0435\u0442
    \u2014 \u044D\u0442\u043E \u0438\u043D\u0442\u0435\u0440\u0430\u043A\u0442\u0438\u0432\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E \u0432\u044B\u0431\u043E\u0440\u0435,
    \u0434\u043E\u0432\u0435\u0440\u0438\u0438 \u0438 \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0438
    \u043A \u0442\u043E\u043C\u0443, \u0447\u0442\u043E \u0447\u0430\u0441\u0442\u043E
    \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F \u043D\u0435\u0437\u0430\u043C\u0435\u0447\u0435\u043D\u043D\u044B\u043C.\n\n\u0418\u0433\u0440\u0430
    \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u0435\u0442 \u0442\u0435\u043C\u0443
    \u0434\u043E\u043C\u0430\u0448\u043D\u0435\u0433\u043E \u043D\u0430\u0441\u0438\u043B\u0438\u044F
    \u2014  \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0438
    \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u2014 \u0438 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0435 \u0432\u0441\u0435\u0433\u0434\u0430
    \u0440\u0435\u0430\u043B\u044C\u043D\u043E \u0440\u0430\u0441\u043F\u043E\u0437\u043D\u0430\u0442\u044C.\n\n\u0417\u0434\u0435\u0441\u044C
    \u043D\u0435\u0442 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0445
    \u043E\u0442\u0432\u0435\u0442\u043E\u0432.\n\u0422\u043E\u043B\u044C\u043A\u043E
    \u0442\u0432\u043E\u0439 \u043F\u0443\u0442\u044C."
  m_isRightToLeft: 0
